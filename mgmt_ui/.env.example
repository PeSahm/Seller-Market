# Seller-Market mgmt UI — environment variable reference.
#
# For a single-VPS production deploy, run mgmt_ui/deploy/deploy.sh — it
# generates secrets and writes /opt/seller-market-mgmt/.env automatically.
# This file documents every recognised variable for manual / dev setups.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Postgres connection. For the bundled docker-compose stack, the service
# hostname is `postgres`. Adjust user / password / host as needed.
POSTGRES_DB=mgmt_ui
POSTGRES_USER=mgmt
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://mgmt:changeme@postgres:5432/mgmt_ui

# JWT signing key — backs the access_token cookie and the short-lived
# ws-token. Min 32 chars; regenerate by openssl rand -base64 48.
MGMT_SECRET_KEY=replace-with-openssl-rand-base64-48

# CSRF HMAC secret (min 32 chars). Rotating this invalidates active CSRF
# tokens (users have to reload any open page) but NOT login cookies.
# openssl rand -base64 48
MGMT_CSRF_SECRET=replace-with-openssl-rand-base64-48

# Fernet key, part 1. Encrypts the broker passwords stored in customers
# rows and the encrypted-password server credentials.
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MGMT_FERNET_KEY_PART1=replace-with-fernet-generate-key

# ---------------------------------------------------------------------------
# Production hardening (recommended)
# ---------------------------------------------------------------------------

# Path on the mgmt VPS to a chmod-400 file holding the Fernet key's second
# half. With BOTH halves present, encrypt() XORs them before deriving the
# Fernet symmetric key — so a one-sided compromise (env leak OR file leak)
# can't decrypt. Optional; leave unset for the single-secret model.
# MGMT_FERNET_KEY_PART2_PATH=/etc/sm/key.part2

# Set Secure flag on cookies. Required when serving over HTTPS — browsers
# refuse to attach Secure cookies on plain http://. Leave at false for
# IP-based plain-HTTP access (the deploy.sh default).
COOKIE_SECURE=false

# Versioned keyset for online Fernet rotation. Set both together. Phase 10
# rotation flow: add new key as v=N+1, bump CURRENT_VERSION, redeploy,
# old envelopes still decrypt; lazy re-encrypt on next mutation.
# MGMT_FERNET_KEY_VERSIONS={"1":"<key1>","2":"<key2>"}
# MGMT_FERNET_CURRENT_VERSION=2

# Environment label — informational, used in some log lines.
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Defaults / tuning
# ---------------------------------------------------------------------------

# Initial Settings → "OCR service URL" value. Admin can override in /admin/settings.
DEFAULT_OCR_SERVICE_URL=http://5.10.248.55:18080

# Where run logs (captured stdout/stderr from each `docker exec`) are archived.
# The janitor cleans up files older than JANITOR_RUN_LOG_RETENTION_DAYS.
RUN_LOGS_DIR=/var/lib/run_logs

# ---------------------------------------------------------------------------
# Background workers — all enabled by default, useful to disable in tests
# or one-off ops mode.
# ---------------------------------------------------------------------------

ENABLE_HEALTH_WORKER=true              # Phase 2: per-server heartbeat + clock skew
ENABLE_STACK_HEALTH_WORKER=true        # Phase 3: docker compose ps on each stack
ENABLE_TRADE_INGESTOR=true             # Phase 7: pulls order_results JSON
TRADE_INGEST_INTERVAL_SECONDS=30

ENABLE_HEALTH_SCANNER=true             # Phase 8: tail trading_bot.log → health_signals
HEALTH_SCAN_INTERVAL_SECONDS=60

ENABLE_JANITOR=true                    # Phase 8: cleans up order_results, run logs, acked signals
JANITOR_INTERVAL_SECONDS=3600
JANITOR_ORDER_RESULTS_RETENTION_DAYS=14
JANITOR_RUN_LOG_RETENTION_DAYS=90
JANITOR_HEALTH_SIGNAL_RETENTION_DAYS=30
