# Postgres
POSTGRES_DB=mgmt_ui
POSTGRES_USER=mgmt
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://mgmt:changeme@postgres:5432/mgmt_ui

# App secrets
MGMT_SECRET_KEY=replace-with-openssl-rand-base64-48
MGMT_FERNET_KEY_PART1=replace-with-fernet-generate-key

# Second half of Fernet key lives on disk at /etc/sm/key.part2 (chmod 400)
# See docs/management-ui-plan.md for the split-key security model.

# Optional: override default OCR URL on first run (admin can change later in UI)
DEFAULT_OCR_SERVICE_URL=http://5.10.248.55:18080
